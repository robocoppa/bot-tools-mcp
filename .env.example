# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# On the box this lives at /mnt/user/appdata/bot-tools/.env (shared with the
# backend stacks). Every credential is PER BOT — no shared accounts.

# --- Email (Brevo smarthost) ---
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=            # your Brevo login / SMTP user
BREVO_SMTP_KEY=             # a Brevo SMTP key (NOT your account password)
MAIL_DOMAIN=example.com     # bots send as <bot>@MAIL_DOMAIN

# --- Calendar (Radicale, internal URL) ---
# Username on the CalDAV side is the bot name; one password per bot (owner_only).
RADICALE_URL=http://radicale:5232
RADICALE_PASS_BRIGITTE=
RADICALE_PASS_CLAUDETTE=
RADICALE_PASS_DONNA=

# --- Docs/sheets (Nextcloud) ---
# Backend I/O uses the INTERNAL url; the PUBLIC url is only ever put into a
# returned share link (a server-side call to the public url hairpins and fails).
# One Nextcloud user per bot, each with its own APP password (not the login pw).
NEXTCLOUD_URL=http://nextcloud:80
NEXTCLOUD_PUBLIC_URL=https://cloud.example.com
NEXTCLOUD_APP_PASSWORD_BRIGITTE=
NEXTCLOUD_APP_PASSWORD_CLAUDETTE=
NEXTCLOUD_APP_PASSWORD_DONNA=

# --- Per-bot MCP tokens ---
# The token IS the bot's identity. Mint with: openssl rand -hex 32
# BOT_TOKEN_<NAME>=<token>  ->  that token authenticates as bot <name>.
BOT_TOKEN_BRIGITTE=
BOT_TOKEN_CLAUDETTE=
BOT_TOKEN_DONNA=

# --- Server bind (optional; these are the defaults) ---
# MCP_HOST=0.0.0.0
# MCP_PORT=9110
